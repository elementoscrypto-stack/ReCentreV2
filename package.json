*{box-sizing:border-box}body{margin:0;background:var(--bg);color:var(--text);font-family:Inter,ui-sans-serif,system-ui,-apple-system,Segoe UI,Arial,sans-serif}h1,h2,h3,p{margin-top:0}h1{font-size:clamp(38px,6vw,88px);line-height:.85;letter-spacing:-.07em}h2{font-size:clamp(24px,3vw,42px);letter-spacing:-.045em}h3{font-size:22px;letter-spacing:-.035em}.muted{color:var(--muted);line-height:1.6}.section-kicker{text-transform:uppercase;letter-spacing:.22em;color:var(--cyan);font-size:11px;font-weight:900;margin-bottom:10px}.projection-label span{font-size:11px;letter-spacing:.2em;color:var(--cyan);text-transform:uppercase}.projection-label p{color:var(--muted)}
