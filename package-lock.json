.app-shell{min-height:100vh;overflow:hidden;position:relative;background:radial-gradient(circle at 50% 10%,rgba(120,247,255,.15),transparent 34%),radial-gradient(circle at 80% 30%,rgba(255,95,215,.12),transparent 32%),#030611}.hero-surface{position:relative;z-index:2;margin-left:92px;padding:26px;min-height:100vh}.topbar{display:flex;align-items:center;justify-content:space-between;gap:20px;margin-bottom:18px}.topbar small{color:var(--muted);text-transform:uppercase;letter-spacing:.2em}.topbar h1{font-size:42px;margin:4px 0 0}.status-pill{border:1px solid rgba(120,247,255,.25);border-radius:999px;background:rgba(120,247,255,.08);padding:12px 16px;color:#d9fdff;font-weight:800;box-shadow:0 0 40px rgba(120,247,255,.13)}.nav-rail{position:fixed;left:18px;top:18px;bottom:18px;z-index:5;width:58px;border:1px solid var(--line);border-radius:28px;background:linear-gradient(180deg,rgba(255,255,255,.11),rgba(255,255,255,.035));backdrop-filter:blur(22px);display:flex;flex-direction:column;align-items:center;gap:22px;padding:14px 8px;box-shadow:0 30px 80px rgba(0,0,0,.45)}.nav-rail span{writing-mode:vertical-rl;font-size:10px;text-transform:uppercase;letter-spacing:.18em;color:rgba(255,255,255,.45)}.brand-mark{height:38px;width:38px;border-radius:16px;display:grid;place-items:center;background:linear-gradient(135deg,rgba(120,247,255,.25),rgba(255,95,215,.2));border:1px solid rgba(120,247,255,.35);font-weight:950}.signal-ribbon{display:grid;grid-template-columns:repeat(5,minmax(0,1fr));gap:10px;margin-bottom:16px}.pulse-grid{display:grid;grid-template-columns:1.1fr .9fr .8fr;gap:16px}.company-core-panel{grid-row:span 2}.timeline-panel,.time-machine{grid-column:1/-1}.core-stats{display:grid;grid-template-columns:repeat(3,1fr);gap:10px;margin-top:16px}@media(max-width:1100px){.pulse-grid,.signal-ribbon{grid-template-columns:1fr 1fr}.company-core-panel,.timeline-panel,.time-machine{grid-column:1/-1}}@media(max-width:760px){.hero-surface{margin-left:0;padding:16px 12px 90px}.nav-rail{left:12px;right:12px;top:auto;bottom:12px;width:auto;height:60px;flex-direction:row;justify-content:center}.nav-rail span{writing-mode:horizontal-tb}.pulse-grid,.signal-ribbon,.core-stats{grid-template-columns:1fr}.topbar{align-items:flex-start;flex-direction:column}}
